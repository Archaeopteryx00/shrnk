{
    "services": {
        "frontend": {
            "root": "frontend",
            "framework": "vite",
            "routes": [
                {
                    "src": "/(assets/.*|.*\\.(?:png|svg|ico|js|css|webp|jpg|jpeg|woff|woff2|ttf))",
                    "transforms": [
                        { "type": "request.path", "op": "set", "args": "/$1" }
                    ]
                },
                {
                    "src": "/(.*)",
                    "transforms": [
                        { "type": "request.path", "op": "set", "args": "/index.html" }
                    ]
                }
            ]
        },
        "backend": {
            "root": "backend",
            "entrypoint": "src/app.js"
        }
    },
    "rewrites": [
        {
            "source": "/api(/.*)?",
            "destination": {
                "type": "service",
                "service": "backend"
            }
        },
        {
            "source": "/:shortCode((?!login|register|dashboard|links|api|assets|favicon|logo|icon|icons|vite|src)[a-zA-Z0-9-_]{3,30})",
            "destination": {
                "type": "service",
                "service": "backend"
            }
        },
        {
            "source": "/(.*)",
            "destination": {
                "type": "service",
                "service": "frontend"
            }
        }
    ]
}
